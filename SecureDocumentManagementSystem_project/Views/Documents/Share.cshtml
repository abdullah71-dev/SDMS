@model int

@{
    ViewBag.Title = "مشاركة المستند";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-white text-center">
                <h4>مشاركة المستند</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Share", "Documents", FormMethod.Post))
                {
                    @Html.Hidden("documentId", Model)

                    <div class="form-group">
                        <label>اختر المستخدم</label>
                        @Html.DropDownList("sharedWithUserId", (SelectList)ViewBag.Users, "-- اختر مستخدم --", new { @class = "form-control" })
                    </div>

                    <div class="form-group">
                        <label>الصلاحية</label>
                        <select name="permission" class="form-control">
                            <option value="View">عرض فقط</option>
                            <option value="Edit">تعديل</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-warning btn-block">مشاركة</button>
                }
            </div>
        </div>
    </div>
</div>
